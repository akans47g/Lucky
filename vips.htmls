<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>VIP Signal | SignalPro AI</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    :root{
      --bg:#070710;
      --card:#0f0f1e;
      --card2:#161628;
      --card3:#1e1e38;
      --border:rgba(255,255,255,0.06);
      --gold:#f5c518; --gold2:#ffd740;
      --green:#00e676; --green2:#00c853;
      --red:#ff4757; --red2:#ff1744;
      --purple:#9c6fff; --purple2:#ce93d8;
      --orange:#ff9100;
      --white:#f0f0ff; --gray:#7070a0; --gray2:#303060;
      --big-col:#00e676; --small-col:#f5c518;
      --nav-h:66px;
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      background:var(--bg); color:var(--white);
      font-family:'Rajdhani',sans-serif;
      min-height:100vh;
      padding-bottom:calc(var(--nav-h) + 24px);
      overflow-x:hidden;
    }

    /* animated bg */
    body::before{
      content:''; position:fixed; inset:0; pointer-events:none; z-index:0;
      background:
        radial-gradient(ellipse at 20% 20%, rgba(156,111,255,0.07) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 80%, rgba(245,197,24,0.05) 0%, transparent 50%),
        radial-gradient(ellipse at 50% 50%, rgba(0,230,118,0.03) 0%, transparent 60%);
      animation:bg-shift 12s ease-in-out infinite alternate;
    }
    @keyframes bg-shift{
      0%{opacity:.7; transform:scale(1)}
      100%{opacity:1; transform:scale(1.05)}
    }

    /* ── LOADING ── */
    #loadingOverlay{
      position:fixed; inset:0; z-index:900; background:var(--bg);
      display:flex; flex-direction:column; align-items:center; justify-content:center; gap:20px;
    }
    #loadingOverlay.hidden{display:none}
    .loader-logo{
      width:70px; height:70px; border-radius:50%;
      border:3px solid rgba(245,197,24,0.15);
      box-shadow:0 0 30px rgba(245,197,24,0.1);
      overflow:hidden; position:relative;
    }
    .loader-ring{
      position:absolute; inset:-3px; border-radius:50%;
      border:3px solid transparent;
      border-top-color:var(--gold); border-right-color:rgba(245,197,24,0.3);
      animation:spin .9s linear infinite;
    }
    @keyframes spin{to{transform:rotate(360deg)}}
    .loader-txt{
      font-family:'Orbitron',sans-serif; font-size:11px;
      color:var(--gray); letter-spacing:3px; text-transform:uppercase;
    }
    .loader-dots{display:flex;gap:6px}
    .loader-dot{
      width:6px; height:6px; border-radius:50%; background:var(--gold);
      animation:dot-bounce .8s ease-in-out infinite;
    }
    .loader-dot:nth-child(2){animation-delay:.15s; background:var(--green);}
    .loader-dot:nth-child(3){animation-delay:.30s; background:var(--purple);}
    @keyframes dot-bounce{0%,100%{transform:translateY(0);opacity:.4}50%{transform:translateY(-8px);opacity:1}}

    /* ── TOAST ── */
    #toast{
      position:fixed; top:16px; left:50%;
      transform:translateX(-50%) translateY(-10px);
      z-index:1000; padding:10px 20px; border-radius:12px;
      font-size:13px; font-weight:700; opacity:0; pointer-events:none;
      transition:opacity .3s,transform .3s; white-space:nowrap; max-width:92vw; text-align:center;
    }
    #toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
    #toast.hidden{display:none}
    #toast.success{background:rgba(0,230,118,.12);border:1px solid var(--green);color:var(--green)}
    #toast.warn{background:rgba(255,145,0,.12);border:1px solid var(--orange);color:var(--orange)}
    #toast.error{background:rgba(255,71,87,.12);border:1px solid var(--red);color:var(--red)}
    #toast.info{background:rgba(156,111,255,.12);border:1px solid var(--purple);color:var(--purple2)}

    /* ── HEADER ── */
    header{
      position:sticky; top:0; z-index:200; height:58px;
      background:rgba(7,7,16,0.95); backdrop-filter:blur(24px);
      border-bottom:1px solid rgba(245,197,24,0.15);
      display:flex; align-items:center; justify-content:space-between;
      padding:0 16px;
    }
    .hd-left{display:flex;align-items:center;gap:8px}
    .live-pill{
      display:flex; align-items:center; gap:5px;
      background:rgba(0,230,118,0.08); border:1px solid rgba(0,230,118,0.3);
      border-radius:20px; padding:3px 10px;
    }
    .live-dot{
      width:6px; height:6px; border-radius:50%; background:var(--green);
      box-shadow:0 0 6px var(--green), 0 0 12px var(--green);
      animation:lp 1.2s ease-in-out infinite;
    }
    @keyframes lp{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.7);opacity:.4}}
    .live-text{font-size:9px;color:var(--green);font-weight:800;letter-spacing:2px}
    .hd-title{
      font-family:'Orbitron',sans-serif;
      font-size:clamp(11px,2.8vw,14px); font-weight:900; letter-spacing:2px;
      background:linear-gradient(90deg,var(--gold),var(--gold2),#fff8dc,var(--gold));
      background-size:300%; -webkit-background-clip:text; -webkit-text-fill-color:transparent;
      animation:shimmer 3s linear infinite;
    }
    @keyframes shimmer{0%{background-position:0%}100%{background-position:300%}}
    .hd-logo{
      width:38px; height:38px; border-radius:50%;
      border:1.5px solid rgba(245,197,24,0.5);
      box-shadow:0 0 14px rgba(245,197,24,0.25);
      overflow:hidden; background:var(--card2);
      display:flex; align-items:center; justify-content:center; flex-shrink:0;
    }
    .hd-logo img{width:100%;height:100%;object-fit:cover;display:block}
    .hd-logo .lf{font-family:'Orbitron',sans-serif;font-size:11px;font-weight:900;color:var(--gold);display:none}

    /* ── MAIN ── */
    main{
      position:relative; z-index:1;
      max-width:460px; margin:0 auto;
      padding:14px 13px 10px;
    }

    /* ── SUBSCRIPTION CARD ── */
    .sub-card{
      border-radius:20px; padding:16px;
      margin-bottom:14px; position:relative; overflow:hidden;
      background:linear-gradient(135deg,#091809,#0a1f0a,#06160a);
      border:1px solid rgba(0,230,118,0.25);
      box-shadow:0 8px 32px rgba(0,230,118,0.08), inset 0 1px 0 rgba(0,230,118,0.1);
      animation:rv .5s cubic-bezier(.22,.68,0,1.2) both;
    }
    .sub-card::before{
      content:''; position:absolute; inset:0; pointer-events:none;
      background:radial-gradient(ellipse at 50% -20%, rgba(0,230,118,0.12) 0%, transparent 70%);
    }
    .sub-card::after{
      content:''; position:absolute; top:0; left:-100%; width:60%; height:100%;
      background:linear-gradient(90deg,transparent,rgba(0,230,118,0.04),transparent);
      animation:sweep 5s ease-in-out infinite;
    }
    @keyframes sweep{0%{left:-100%}60%,100%{left:150%}}
    .sc-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;position:relative}
    .sc-badge{
      display:flex; align-items:center; gap:5px;
      background:rgba(0,230,118,0.1); border:1px solid rgba(0,230,118,0.3);
      border-radius:20px; padding:3px 10px;
      font-size:10px; color:var(--green); font-weight:800; letter-spacing:1.5px;
    }
    .sc-dot{width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green);animation:lp 1.2s ease-in-out infinite}
    .sc-name{
      font-family:'Orbitron',sans-serif; font-size:13px; font-weight:900;
      color:var(--green); position:relative;
      text-shadow:0 0 20px rgba(0,230,118,0.4);
    }
    .cd-row{display:flex;gap:7px;justify-content:center;position:relative}
    .cd-box{
      flex:1; background:rgba(0,0,0,0.4); border:1px solid rgba(0,230,118,0.15);
      border-radius:10px; padding:10px 6px; text-align:center;
      backdrop-filter:blur(4px);
    }
    .cd-num{
      font-family:'Orbitron',sans-serif; font-size:22px; font-weight:900;
      color:var(--green); line-height:1;
      text-shadow:0 0 16px rgba(0,230,118,0.5);
    }
    .cd-lbl{font-size:8px;color:var(--gray);margin-top:4px;letter-spacing:1px;text-transform:uppercase}

    /* ── PLATFORM SECTION ── */
    .platform-section{
      background:var(--card); border-radius:18px;
      border:1px solid var(--border);
      padding:16px; margin-bottom:14px;
      animation:rv .5s .07s cubic-bezier(.22,.68,0,1.2) both;
    }
    .platform-section.hidden{display:none}
    .ps-head{display:flex;align-items:center;gap:8px;margin-bottom:10px}
    .ps-icon{font-size:18px}
    .ps-title{font-size:14px;font-weight:800;color:var(--white)}
    .ps-hint{font-size:11px;color:var(--gray);margin-bottom:12px;line-height:1.6}
    .url-row{display:flex;gap:8px}
    .url-input{
      flex:1; background:var(--card2);
      border:1.5px solid var(--border);
      border-radius:12px; padding:12px 14px;
      color:var(--white); font-size:13px; font-family:'Rajdhani',sans-serif;
      outline:none; transition:border-color .2s, box-shadow .2s;
    }
    .url-input:focus{border-color:rgba(156,111,255,.4);box-shadow:0 0 0 3px rgba(156,111,255,.07)}
    .url-input::placeholder{color:var(--gray2)}
    .url-submit-btn{
      background:linear-gradient(135deg,var(--purple),var(--gold));
      color:#000; border:none; border-radius:12px;
      padding:12px 18px; font-size:13px; font-weight:900;
      cursor:pointer; font-family:'Rajdhani',sans-serif; letter-spacing:.5px;
      transition:transform .15s; white-space:nowrap;
    }
    .url-submit-btn:active{transform:scale(.97)}

    /* ── CHANGE URL PILL (small, top of signal box) ── */
    .change-url-pill{
      display:none; align-items:center; justify-content:space-between;
      background:rgba(156,111,255,0.06); border:1px solid rgba(156,111,255,0.15);
      border-radius:10px; padding:7px 12px; margin-bottom:10px;
      animation:rv .4s cubic-bezier(.22,.68,0,1.2) both;
    }
    .change-url-pill.show{display:flex}
    .cup-text{font-size:11px;color:var(--gray);font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:calc(100% - 80px)}
    .cup-btn{
      background:none; border:1px solid rgba(156,111,255,0.25);
      border-radius:8px; padding:3px 10px;
      font-size:11px; color:var(--purple2); font-weight:700;
      cursor:pointer; font-family:'Rajdhani',sans-serif; flex-shrink:0;
    }

    /* ── SIGNAL SECTION ── */
    #signalSection{display:none}
    #signalSection.visible{display:block;animation:rv .6s cubic-bezier(.22,.68,0,1.2) both}

    /* Outer signal card */
    .signal-outer{
      border-radius:22px; overflow:hidden; position:relative;
      margin-bottom:0;
      background:linear-gradient(160deg,#0c1630,#111830,#0a1020);
      border:1px solid rgba(255,255,255,0.07);
      box-shadow:0 20px 60px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.05);
    }

    /* Top colored bar based on signal */
    .signal-bar{
      height:3px; width:100%;
      background:linear-gradient(90deg,transparent,var(--green),transparent);
      transition:background .4s;
    }
    .signal-bar.small-bar{
      background:linear-gradient(90deg,transparent,var(--gold),transparent);
    }

    .signal-pad{padding:20px 18px 18px}

    /* Inner white card */
    .signal-inner{
      background:#ffffff; border-radius:14px;
      padding:24px 16px 20px; text-align:center;
      margin-bottom:18px;
      box-shadow:0 8px 30px rgba(0,0,0,0.4);
      position:relative; overflow:hidden;
    }
    .signal-inner::before{
      content:''; position:absolute; inset:0;
      background:linear-gradient(160deg,rgba(255,255,255,1) 0%,rgba(245,248,255,1) 100%);
    }
    .signal-word{
      font-family:'Orbitron',sans-serif; font-weight:900;
      font-size:clamp(52px,16vw,80px); line-height:1;
      letter-spacing:3px; position:relative;
      transition:all .35s cubic-bezier(.22,.68,0,1.2);
      -webkit-text-stroke:3px #000;
    }
    .signal-word.BIG{
      color:var(--big-col);
      -webkit-text-stroke:3px #004d20;
      filter:drop-shadow(0 4px 12px rgba(0,230,118,0.3));
    }
    .signal-word.SMALL{
      color:var(--gold);
      -webkit-text-stroke:3px #5a3e00;
      filter:drop-shadow(0 4px 12px rgba(245,197,24,0.3));
    }
    .signal-id{
      font-family:'Orbitron',sans-serif; font-weight:700;
      font-size:clamp(11px,3vw,14px); color:#1a1a3a;
      letter-spacing:1.5px; margin-top:12px; position:relative;
      word-break:break-all;
    }

    /* Percent row */
    .pct-row{
      display:flex; align-items:center; justify-content:center; gap:6px;
      margin-bottom:16px;
    }
    .pct-num{
      font-family:'Orbitron',sans-serif; font-weight:900;
      font-size:clamp(22px,7vw,30px); line-height:1;
      animation:pct-glow 2s ease-in-out infinite alternate;
    }
    .pct-num.big-pct{color:var(--green)}
    .pct-num.small-pct{color:var(--gold)}
    @keyframes pct-glow{
      from{text-shadow:0 0 10px rgba(245,197,24,0.3)}
      to  {text-shadow:0 0 24px rgba(245,197,24,0.8),0 0 40px rgba(245,197,24,0.3)}
    }
    .pct-label{font-size:15px;font-weight:700;color:rgba(255,255,255,0.7)}

    /* Timer */
    .timer-wrap{margin-bottom:16px}
    .timer-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}
    .timer-lbl{font-size:10px;color:var(--gray);font-weight:700;letter-spacing:1.5px;text-transform:uppercase}
    .timer-sec{
      font-family:'Orbitron',sans-serif; font-size:12px;
      font-weight:900; color:var(--green);
      background:rgba(0,230,118,0.08); border:1px solid rgba(0,230,118,0.2);
      border-radius:6px; padding:2px 8px;
    }
    .timer-track{
      height:5px; background:rgba(255,255,255,0.06);
      border-radius:10px; overflow:hidden;
    }
    .timer-fill{
      height:100%; border-radius:10px;
      background:linear-gradient(90deg,var(--green),var(--gold));
      transition:width 1s linear;
      box-shadow:0 0 8px rgba(0,230,118,0.4);
    }

    /* Previous prediction */
    .prev-box{
      background:rgba(0,0,0,0.3); border-radius:14px;
      padding:14px 16px; border:1px solid rgba(255,255,255,0.05);
      backdrop-filter:blur(4px);
    }
    .prev-head{
      font-size:10px; color:var(--gray); font-weight:700;
      letter-spacing:2px; text-transform:uppercase;
      margin-bottom:8px; display:flex; align-items:center; gap:6px;
    }
    .prev-head::after{content:'';flex:1;height:1px;background:rgba(255,255,255,0.06)}
    .prev-id{
      font-family:'Orbitron',sans-serif; font-size:9px;
      color:rgba(255,255,255,0.25); margin-bottom:8px;
      word-break:break-all; letter-spacing:.5px;
    }
    .prev-text{
      font-size:13px; color:rgba(255,255,255,0.65);
      line-height:1.8; text-align:center; font-style:italic;
    }
    .prev-text strong{font-style:normal;font-weight:900}
    .prev-big  {color:var(--green);font-weight:900;font-style:normal}
    .prev-small{color:var(--gold);font-weight:900;font-style:normal}

    /* ── BOTTOM NAV ── */
    .bottom-nav{
      position:fixed; bottom:0; left:0; right:0;
      height:var(--nav-h); z-index:200;
      background:rgba(7,7,16,0.97);
      backdrop-filter:blur(24px);
      border-top:1px solid rgba(245,197,24,0.12);
      display:flex; align-items:stretch;
      box-shadow:0 -4px 20px rgba(0,0,0,0.5);
    }
    .nav-btn{
      flex:1; display:flex; flex-direction:column;
      align-items:center; justify-content:center; gap:3px;
      background:none; border:none; cursor:pointer;
      color:var(--gray); font-size:8px; font-weight:700;
      letter-spacing:.8px; text-transform:uppercase; position:relative;
    }
    .nav-btn .ni{font-size:20px;line-height:1;transition:transform .2s}
    .nav-btn.active{color:var(--purple)}
    .nav-btn.active .ni{transform:translateY(-2px)}
    .nav-btn.active::after{
      content:''; position:absolute; top:0; left:18%; right:18%; height:2px;
      border-radius:0 0 3px 3px;
      background:linear-gradient(90deg,transparent,var(--purple),transparent);
    }

    /* ── FLASH ANIMATION ── */
    @keyframes flash-big  {0%,100%{box-shadow:0 20px 60px rgba(0,0,0,0.6)}50%{box-shadow:0 20px 60px rgba(0,0,0,0.6),0 0 40px rgba(0,230,118,0.2)}}
    @keyframes flash-small{0%,100%{box-shadow:0 20px 60px rgba(0,0,0,0.6)}50%{box-shadow:0 20px 60px rgba(0,0,0,0.6),0 0 40px rgba(245,197,24,0.2)}}
    .signal-outer.flash-big  {animation:flash-big   .4s ease-out}
    .signal-outer.flash-small{animation:flash-small .4s ease-out}

    @keyframes rv{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
    .hidden{display:none!important}
  </style>
</head>
<body>

<!-- LOADING -->
<div id="loadingOverlay">
  <div class="loader-logo">
    <div class="loader-ring"></div>
  </div>
  <div class="loader-txt">Checking VIP Access</div>
  <div class="loader-dots">
    <div class="loader-dot"></div>
    <div class="loader-dot"></div>
    <div class="loader-dot"></div>
  </div>
</div>

<div id="toast" class="toast hidden"></div>

<!-- HEADER -->
<header>
  <div class="hd-left">
    <div class="live-pill">
      <div class="live-dot"></div>
      <span class="live-text">LIVE</span>
    </div>
  </div>
  <div class="hd-title">VIP Signal</div>
  <div class="hd-logo">
    <img src="https://raw.githubusercontent.com/akans47g/Lucky/main/logo.jpg" alt="Logo"
         onerror="this.style.display='none';this.nextElementSibling.style.display='block';"/>
    <span class="lf">SP</span>
  </div>
</header>

<main>

  <!-- SUBSCRIPTION CARD -->
  <div class="sub-card">
    <div class="sc-top">
      <div class="sc-badge"><div class="sc-dot"></div> VIP ACTIVE</div>
      <div class="sc-name" id="activePlanName">Loading...</div>
    </div>
    <div class="cd-row">
      <div class="cd-box"><div class="cd-num" id="ssDays">00</div><div class="cd-lbl">Days</div></div>
      <div class="cd-box"><div class="cd-num" id="ssHrs">00</div><div class="cd-lbl">Hrs</div></div>
      <div class="cd-box"><div class="cd-num" id="ssMin">00</div><div class="cd-lbl">Min</div></div>
      <div class="cd-box"><div class="cd-num" id="ssSec">00</div><div class="cd-lbl">Sec</div></div>
    </div>
  </div>

  <!-- PLATFORM URL SECTION (hides after submit) -->
  <div class="platform-section" id="platformSection">
    <div class="ps-head">
      <span class="ps-icon">🌐</span>
      <span class="ps-title">Enter Your Trading Platform</span>
    </div>
    <div class="ps-hint">Jis website par aap trading karte ho us ka URL dale</div>
    <div class="url-row">
      <input class="url-input" type="url" id="platformUrl" placeholder="https://your-platform.com"/>
      <button class="url-submit-btn" onclick="submitPlatform()">Submit</button>
    </div>
  </div>

  <!-- SIGNAL SECTION -->
  <div id="signalSection">

    <!-- Small change URL pill (visible after URL saved) -->
    <div class="change-url-pill" id="changeUrlPill">
      <span class="cup-text" id="cupText">🌐 —</span>
      <button class="cup-btn" onclick="changePlatform()">Change</button>
    </div>

    <!-- Signal box -->
    <div class="signal-outer" id="signalOuter">
      <div class="signal-bar" id="signalBar"></div>
      <div class="signal-pad">

        <!-- White inner card -->
        <div class="signal-inner">
          <div class="signal-word BIG" id="signalWord">BIG</div>
          <div class="signal-id" id="signalId">20260602100019371</div>
        </div>

        <!-- Percentage -->
        <div class="pct-row">
          <span class="pct-num big-pct" id="pctNum">76</span>
          <span class="pct-label">% Chance Of <span id="pctDir">Big</span></span>
        </div>

        <!-- Timer bar -->
        <div class="timer-wrap">
          <div class="timer-top">
            <span class="timer-lbl">Next Signal In</span>
            <span class="timer-sec" id="timerSec">60s</span>
          </div>
          <div class="timer-track">
            <div class="timer-fill" id="timerFill" style="width:100%"></div>
          </div>
        </div>

        <!-- Previous prediction -->
        <div class="prev-box">
          <div class="prev-head">📋 Previous Prediction</div>
          <div class="prev-id" id="prevId"></div>
          <div class="prev-text" id="prevText"></div>
        </div>

      </div>
    </div>

  </div>

</main>

<!-- BOTTOM NAV -->
<nav class="bottom-nav">
  <button class="nav-btn" onclick="location.href='index.html'"><span class="ni">🏠</span>Home</button>
  <button class="nav-btn active"><span class="ni">💎</span>VIP Shot</button>
  <button class="nav-btn" onclick="location.href='proof.html'"><span class="ni">📊</span>Proof</button>
  <button class="nav-btn" onclick="location.href='account.html'"><span class="ni">👤</span>Account</button>
</nav>

<!-- ══ SIGNAL LOGIC ══ -->
<script>
/* ── Seeded random — same for all users same minute ── */
function seededRand(seed){
  let s=(seed^0xdeadbeef)>>>0;
  s=Math.imul(s^(s>>>16),0x45d9f3b)>>>0;
  s=Math.imul(s^(s>>>16),0x45d9f3b)>>>0;
  return (s^(s>>>16))>>>0 / 4294967296;
}
function getMinuteKey(){ return Math.floor(Date.now()/60000); }

function genSignal(mKey){
  const dir = seededRand(mKey) > 0.5 ? 'BIG' : 'SMALL';
  const pct = Math.floor(seededRand(mKey+77777)*26)+60;
  return {dir,pct};
}
function genId(mKey){
  const d=new Date();
  const dt=`${d.getFullYear()}${String(d.getMonth()+1).padStart(2,'0')}${String(d.getDate()).padStart(2,'0')}`;
  return `${dt}10001${String((mKey%9000)+1000)}`;
}
function genPrevPct(mKey){ return Math.floor(seededRand(mKey-1+99999)*31)+60; }

/* ── Update signal UI ── */
function updateSignal(){
  const mKey  = getMinuteKey();
  const cur   = genSignal(mKey);
  const prev  = genSignal(mKey-1);
  const curId = genId(mKey);
  const preId = genId(mKey-1);
  const prevPct = genPrevPct(mKey);

  /* Word */
  const wEl = document.getElementById('signalWord');
  wEl.textContent = cur.dir;
  wEl.className   = `signal-word ${cur.dir}`;

  /* ID */
  document.getElementById('signalId').textContent = curId;

  /* Top bar color */
  const bar = document.getElementById('signalBar');
  bar.className = cur.dir === 'BIG' ? 'signal-bar' : 'signal-bar small-bar';

  /* Pct */
  const pEl = document.getElementById('pctNum');
  pEl.textContent = cur.pct;
  pEl.className   = cur.dir==='BIG' ? 'pct-num big-pct' : 'pct-num small-pct';
  document.getElementById('pctDir').textContent = cur.dir==='BIG'?'Big':'Small';

  /* Previous */
  document.getElementById('prevId').textContent = preId;
  const pDirCls = prev.dir==='BIG' ? 'prev-big' : 'prev-small';
  const pDirTxt = prev.dir==='BIG' ? 'Big' : 'Small';
  document.getElementById('prevText').innerHTML =
    `I had mentioned <span class="${pDirCls}">${pDirTxt}</span><br>
     in the earlier production too,<br>
     And on <strong>${prevPct}%+</strong> platforms<br>
     it appeared as <span class="${pDirCls}">${pDirTxt}</span> only`;

  /* Flash */
  const outer = document.getElementById('signalOuter');
  const fc = cur.dir==='BIG'?'flash-big':'flash-small';
  outer.classList.remove('flash-big','flash-small');
  void outer.offsetWidth;
  outer.classList.add(fc);
  setTimeout(()=>outer.classList.remove(fc),400);
}

/* ── Timer ── */
let _timerIv = null;
function startTimer(){
  if(_timerIv) clearInterval(_timerIv);
  let lastMin = getMinuteKey();
  function tick(){
    const secLeft = Math.ceil((60000-(Date.now()%60000))/1000);
    const pct     = (secLeft/60)*100;
    document.getElementById('timerSec').textContent  = secLeft+'s';
    document.getElementById('timerFill').style.width = pct+'%';
    const curMin = getMinuteKey();
    if(curMin !== lastMin){ lastMin=curMin; updateSignal(); }
  }
  tick();
  _timerIv = setInterval(tick,1000);
}

/* ── Sub countdown ── */
let _subIv = null;
window.startSubCountdown = function(expiresAt){
  if(_subIv) clearInterval(_subIv);
  function tick(){
    const diff = expiresAt-Date.now();
    if(diff<=0){
      clearInterval(_subIv);
      showToast('⚠️ Plan expire ho gaya! Renew karo.','warn');
      setTimeout(()=>window.location.replace('subs.html'),2000);
      return;
    }
    const d=Math.floor(diff/86400000);
    const h=Math.floor((diff%86400000)/3600000);
    const m=Math.floor((diff%3600000)/60000);
    const s=Math.floor((diff%60000)/1000);
    document.getElementById('ssDays').textContent=String(d).padStart(2,'0');
    document.getElementById('ssHrs').textContent =String(h).padStart(2,'0');
    document.getElementById('ssMin').textContent =String(m).padStart(2,'0');
    document.getElementById('ssSec').textContent =String(s).padStart(2,'0');
  }
  tick(); _subIv=setInterval(tick,1000);
};

/* ── Platform URL ── */
window.submitPlatform = function(){
  const val = document.getElementById('platformUrl').value.trim();
  if(!val||(!val.startsWith('http://')&&!val.startsWith('https://'))){
    showToast('Valid URL dalo (https:// se shuru)','warn'); return;
  }
  localStorage.setItem('sp_platformUrl',val);
  activatePlatform(val);
  showToast('✅ Platform saved! Signal ready.','success');
};

function activatePlatform(url){
  /* Hide platform section completely */
  document.getElementById('platformSection').classList.add('hidden');

  /* Show small change pill */
  const pill = document.getElementById('changeUrlPill');
  document.getElementById('cupText').textContent = '🌐 '+url;
  pill.classList.add('show');

  /* Show signal box */
  const sec = document.getElementById('signalSection');
  sec.style.display='block';
  sec.classList.add('visible');
  updateSignal();
  startTimer();
}

window.showPlatformSaved = activatePlatform;
window.showSignalBox     = function(){};  /* already handled in activatePlatform */

window.changePlatform = function(){
  localStorage.removeItem('sp_platformUrl');
  /* Show platform section again */
  document.getElementById('platformSection').classList.remove('hidden');
  document.getElementById('platformUrl').value='';
  /* Hide pill + signal */
  document.getElementById('changeUrlPill').classList.remove('show');
  const sec=document.getElementById('signalSection');
  sec.style.display='none';
  sec.classList.remove('visible');
  if(_timerIv) clearInterval(_timerIv);
};

/* ── Toast ── */
function showToast(msg,type='info'){
  const t=document.getElementById('toast');
  t.textContent=msg; t.className=`toast ${type}`;
  t.classList.remove('hidden'); void t.offsetWidth; t.classList.add('show');
  setTimeout(()=>{t.classList.remove('show');setTimeout(()=>t.classList.add('hidden'),400);},3200);
}
</script>

<!-- ══ FIREBASE ══ -->
<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getFirestore, doc, getDoc } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";
import { getAuth, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";

const app = initializeApp({
  apiKey:"AIzaSyDh_fzIv1_YLP6X8DzjFdXvvFQv2sciFzU",
  authDomain:"lucky-b3886.firebaseapp.com",
  projectId:"lucky-b3886",
  storageBucket:"lucky-b3886.firebasestorage.app",
  messagingSenderId:"314352804588",
  appId:"1:314352804588:web:96697e2668a95c19affbc9"
});
const db   = getFirestore(app);
const auth = getAuth(app);

function hideLoader(){ document.getElementById('loadingOverlay').classList.add('hidden'); }

onAuthStateChanged(auth, async (user)=>{
  if(!user){ window.location.replace('login.html'); return; }
  try{
    const snap      = await getDoc(doc(db,'users',user.uid));
    const data      = snap.exists() ? snap.data() : {};
    const expires   = data.planExpiresAt;
    let   expiresMs = 0;
    if(expires) expiresMs = expires.toMillis ? expires.toMillis() : new Date(expires).getTime();

    if(!expiresMs || expiresMs <= Date.now()){
      window.location.replace('subs.html'); return;
    }

    localStorage.setItem('sp_planExpires', expiresMs);
    localStorage.setItem('sp_planName',    data.planName||data.plan||'VIP');
    localStorage.setItem('sp_coins',       data.coins??0);

    document.getElementById('activePlanName').textContent = data.planName||data.plan||'VIP';
    window.startSubCountdown(expiresMs);
    hideLoader();

    const savedUrl = localStorage.getItem('sp_platformUrl');
    if(savedUrl) window.activatePlatform(savedUrl);

  } catch(err){
    console.error(err);
    const localExp = parseInt(localStorage.getItem('sp_planExpires')||'0');
    if(localExp > Date.now()){
      document.getElementById('activePlanName').textContent = localStorage.getItem('sp_planName')||'VIP';
      window.startSubCountdown(localExp);
      hideLoader();
      const savedUrl = localStorage.getItem('sp_platformUrl');
      if(savedUrl) window.activatePlatform(savedUrl);
    } else {
      window.location.replace('subs.html');
    }
  }
});

/* expose activatePlatform to module scope too */
window.activatePlatform = window.activatePlatform;
</script>

</body>
</html>
